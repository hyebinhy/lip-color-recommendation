f)\n","        df = total_similarity(df)\n","\n","        recommendations = df[df['Normalized File Name'].str.lower() != input_product.lower()]\n","        return recommendations[['Normalized File Name', 'Total Similarity']].head(num_recommendations)\n","    except ValueError as e:\n","        return str(e)\n","\n","# 사용자 입력 받기\n","input_product = input(\"Enter the product name:\")\n","#input_product = input_product.encode('cp949').encode('utf-8')\n","\n","print(f\"입력된 키워드: {repr(input_product)}\")\n","\n","\n","#with open('euc_kr.txt', encoding='euc-kr', mode='w') as f:\n","#    f.write(input_product)\n","\n","def search_data(df, input_product):\n","    results = df[df['File Name'].str.contains(input_product, na=False)]\n","    return results\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"f1-txnAjQ_DF","executionInfo":{"status":"ok","timestamp":1724914878550,"user_tz":-540,"elapsed":2577,"user":{"displayName":"돌멩이","userId":"08336563713577912677"}},"outputId":"b0752251-cc69-4a49-edd8-e025861b14d6"},"execution_count":9,"outputs":[{"output_type":"stream","name":"stdout","text":["Enter the product name:네이처리퍼블릭_허니멜팅립_쫀득복숭아.png\n","입력된 키워드: '네이처리퍼블릭_허니멜팅립_쫀득복숭아.png'\n"]}]},{"cell_type":"code","source":["# 제품 추천 실행\n","recommendations = recommend_products(input_product, df)\n","print(\"추천 제품:\")\n","print(recommendations)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"I5BFf4sBRopM","executionInfo":{"status":"ok","timestamp":1724914880147,"user_tz":-540,"elapsed":389,"user":{"displayName":"돌멩이","userId":"08336563713577912677"}},"outputId":"703db834-ab5a-4e15-91e5-cb5ab0a244cf"},"execution_count":10,"outputs":[{"output_type":"stream","name":"stdout","text":["추천 제품:\n","Product '네이처리퍼블릭_허니멜팅립_쫀득복숭아.png' not found.\n"]}]},{"cell_type":"code","source":["import matplotlib.pyplot as plt\n","import matplotlib.image as mpimg\n","import os\n","\n","\n","for index